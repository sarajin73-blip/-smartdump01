    setLogs(prev => [newLog, ...prev]);
    if (!registeredPlates.includes(formData.plateNumber)) {
      setRegisteredPlates(prev => [...prev, formData.plateNumber]);
    }

    // 폼 클리어
    setFormData({
      plateNumber: '',
      weight: '24.0',
      driverName: '',
      invoiceAttached: true,
      material: '사토 (일반토)'
    });
  };

  // 행 항목 삭제
  const handleDeleteLog = (id) => {
    setLogs(prev => prev.filter(log => log.id !== id));
  };

  // 다중 인쇄 선택 토글
  const handleSelectLog = (id) => {
    if (selectedLogs.includes(id)) {
      setSelectedLogs(prev => prev.filter(item => item !== id));
    } else {
      setSelectedLogs(prev => [...prev, id]);
    }
  };

  const handleSelectAll = () => {
    if (selectedLogs.length === filteredLogs.length) {
      setSelectedLogs([]);
    } else {
      setSelectedLogs(filteredLogs.map(l => l.id));
    }
  };

  // 모의 가상 파일 첨부 및 자동 OCR 인식 연산기능
  const triggerMockFileOCR = (type) => {
    const randomIdx = Math.floor(Math.random() * mockVehicles.length);
    const mockData = mockVehicles[randomIdx];
    
    if (type === 'PLATE') {
      setFormData(prev => ({
        ...prev,
        plateNumber: mockData.plate,
        driverName: mockData.driver
      }));
    } else if (type === 'INVOICE') {
      setFormData(prev => ({
        ...prev,
        invoiceAttached: true,
        weight: mockData.weight.toString()
      }));
    }
  };

  // 필터링된 기록 일지
  const filteredLogs = logs.filter(log => {
    const matchesSearch = log.plateNumber.includes(searchQuery) || log.driverName.includes(searchQuery) || log.material.includes(searchQuery);
    if (filterInvoice === 'ALL') return matchesSearch;
    if (filterInvoice === 'ATTACHED') return matchesSearch && log.invoiceAttached;
    if (filterInvoice === 'MISSING') return matchesSearch && !log.invoiceAttached;
    return matchesSearch;
  });

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans">
