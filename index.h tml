      if (!registeredPlates.includes(randomVehicle.plate)) {
        setRegisteredPlates(prev => [...prev, randomVehicle.plate]);
      }
    }, 4500);

    setTimeout(() => {
      setSimStep(0);
      setIsSimulating(false);
      setSimDetails(null);
    }, 6500);
  };

  // 수동 간편 간편출차 등록
  const handleManualSubmit = (e) => {
    e.preventDefault();
    if (!formData.plateNumber.trim()) return;

    const now = new Date();
    const timeStr = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}:${String(now.getSeconds()).padStart(2, '0')}`;

    const newLog = {
      id: Date.now(),
      time: timeStr,
      plateNumber: formData.plateNumber,
      plateImg: 'https://images.unsplash.com/photo-1592838064575-70ed626d3a44?auto=format&fit=crop&q=80&w=200', // 디폴트 이미지
      invoiceImg: formData.invoiceAttached ? 'https://images.unsplash.com/photo-1586075010923-2dd45e9b2d4f?auto=format&fit=crop&q=80&w=200' : null,
      invoiceAttached: formData.invoiceAttached,
      weight: parseFloat(formData.weight) || 24.0,
      material: formData.material,
      driverName: formData.driverName || '임시 운전자',
      status: formData.invoiceAttached ? '정상출차' : '송장누락'
