                <div className="absolute inset-0 bg-[radial-gradient(#1e293b_1px,transparent_1px)] [background-size:16px_16px] opacity-30" />
                
                {simStep === 0 && (
                  <div className="my-auto text-center relative z-10 space-y-4">
                    <div className="w-16 h-16 bg-slate-900 rounded-full border border-slate-800 flex items-center justify-center mx-auto text-slate-400">
                      <Camera className="w-8 h-8 animate-pulse text-amber-500" />
                    </div>
                    <div>
                      <h4 className="text-base font-bold">덤프트럭 진입 대기 상태</h4>
                      <p className="text-xs text-slate-400 mt-1">카메라 렌즈 및 인공지능 모듈이 진입로를 모니터링 중입니다.</p>
                    </div>
                  </div>
                )}

                {simStep > 0 && simDetails && (
                  <div className="relative z-10 w-full h-full flex flex-col justify-between space-y-4">
                    <div className="flex flex-col sm:flex-row items-center sm:items-start gap-4">
                      <div className="relative w-28 h-20 rounded-lg overflow-hidden border border-slate-700 bg-slate-900 shrink-0">
                        <img src={simDetails.imgUrl} className="w-full h-full object-cover" alt="Simulated truck" />
                        <div className="absolute inset-0 border-2 border-[#fca215] animate-pulse" />
                        <span className="absolute bottom-1 right-1 bg-black/70 px-1 py-0.5 text-[9px] text-white">CH-01</span>
                      </div>

                      <div className="text-center sm:text-left flex-1 space-y-1">
                        <span className="bg-amber-500 text-slate-950 font-bold px-2 py-0.5 rounded text-[10px] tracking-wider">
                          {simStep === 1 && 'STEP 01: 트럭 진입 감지'}
                          {simStep === 2 && 'STEP 02: 인공지능 번호판 판독'}
                          {simStep === 3 && 'STEP 03: 적재 송장 분석 중'}
                          {simStep === 4 && 'SUCCESS: 데이터베이스 즉시 기록'}
                        </span>
                        
                        <div className="mt-1">
                          <p className="text-xs text-slate-400">검출 운전자 : <strong className="text-white">{simDetails.driver}</strong></p>
                          <p className="text-xs text-slate-400">예측 중량 : <strong className="text-white">{simDetails.weight} 톤</strong></p>
                        </div>
                      </div>
                    </div>

                    <div className="space-y-2">
                      <div className="flex justify-between text-xs text-slate-400 font-bold">
                        <span className={simStep >= 1 ? 'text-[#fca215]' : ''}>감지 완료</span>
                        <span className={simStep >= 2 ? 'text-[#fca215]' : ''}>OCR 추출</span>
                        <span className={simStep >= 3 ? 'text-[#fca215]' : ''}>송장 판별</span>
                        <span className={simStep >= 4 ? 'text-[#0fc58a]' : ''}>DB 등록</span>
                      </div>
                      <div className="w-full bg-slate-800 h-2 rounded-full overflow-hidden">
                        <div 
                          className={`h-full transition-all duration-500 ease-out ${simStep === 4 ? 'bg-[#0fc58a]' : 'bg-[#fca215]'}`}
                          style={{ width: `${(simStep / 4) * 100}%` }}
                        />
